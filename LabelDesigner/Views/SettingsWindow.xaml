<Window x:Class="LabelDesigner.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Settings" Width="640" Height="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="560" MinHeight="540"
        ShowInTaskbar="False">
    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Save" Width="80" Command="{Binding SaveCommand}" IsDefault="True"
                    Background="#2196F3" Foreground="White"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#B00020" TextWrapping="Wrap" FontSize="11"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Serial counter &amp; print-history storage" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"
                           Text="Where CONTINUOUS serial counters and the print history are kept. (Reset-per-batch serials don't use this — they start at the Start Value every job.) Choose a shared folder so several stations share one continuous sequence and a shop-wide audit trail."/>

                <RadioButton GroupName="store" Margin="0,0,0,6"
                             Content="Local — this PC only"
                             IsEnabled="{Binding CanEdit}"
                             IsChecked="{Binding UseShared, Converter={StaticResource InverseBool}}"/>
                <RadioButton GroupName="store" Margin="0,0,0,4"
                             Content="Shared network folder (for multiple stations)"
                             IsEnabled="{Binding CanEdit}"
                             IsChecked="{Binding UseShared}"/>

                <Grid Margin="20,0,0,10" IsEnabled="{Binding CanEditPath}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Padding="4" VerticalContentAlignment="Center"
                             Text="{Binding SharedDir, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="A UNC path is best, e.g. \\server\labels\Data"/>
                    <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="8,2"
                            Command="{Binding BrowseCommand}"/>
                </Grid>

                <Border Background="#FFF8E1" BorderBrush="#E6C200" BorderThickness="1" Padding="6" Margin="0,0,0,8"
                        Visibility="{Binding IsAdminLocked, Converter={StaticResource BoolToVis}}">
                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Text="This location is pinned by appsettings.json or an environment variable, so it can't be changed here."/>
                </Border>

                <TextBlock FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="{Binding EffectiveDataDir, StringFormat=Current location: {0}}"/>

                <!-- ── Watch folders ──────────────────────────────────────── -->
                <TextBlock Text="Watch folders (print jobs from your ERP)" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,8"
                           Text="The Print Station monitors each folder's inbox\ for batch CSV files. A job CSV has a header row of FIELD NAMES (matching the template's fields), plus optional Template, PrintQty columns. Completed jobs move to printed\ with a .result.txt audit file; failures move to failed\ with the reasons — files are never deleted. Auto-print sends valid jobs straight to the printer; otherwise jobs wait in the Print Station queue."/>

                <DataGrid ItemsSource="{Binding WatchFolders}" SelectedItem="{Binding SelectedWatchFolder}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" MinHeight="120" MaxHeight="200" Margin="0,0,0,6">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                        <DataGridTextColumn Header="Folder (root)" Binding="{Binding Path, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridCheckBoxColumn Header="Auto-print" Binding="{Binding AutoPrint, UpdateSourceTrigger=PropertyChanged}" Width="74"/>
                        <DataGridCheckBoxColumn Header="Skip bad rows" Binding="{Binding SkipInvalidRows, UpdateSourceTrigger=PropertyChanged}" Width="92"/>
                        <DataGridTemplateColumn Header="Default template" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox IsEditable="True"
                                              ItemsSource="{Binding DataContext.TemplateNames, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Text="{Binding DefaultTemplate, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Add folder…" Padding="10,3" Margin="0,0,6,0" Command="{Binding AddWatchFolderCommand}"/>
                    <Button Content="Remove" Padding="10,3" Command="{Binding RemoveWatchFolderCommand}"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="#777" FontSize="11"
                           Text="Rows route to a template by their Template column, then the routing rules (Designer ▸ Template ▸ Template Routing…), then this folder's default. The Print Station applies watch-folder changes the next time it starts."/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
