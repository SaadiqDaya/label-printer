<Window x:Class="LabelDesigner.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Settings" Width="470" Height="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="Serial counter &amp; print-history storage" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"
                   Text="Where CONTINUOUS serial counters and the print history are kept. (Reset-per-batch serials don't use this — they start at the Start Value every job.) Choose a shared folder so several stations share one continuous sequence and a shop-wide audit trail."/>

        <RadioButton GroupName="store" Margin="0,0,0,6"
                     Content="Local — this PC only"
                     IsEnabled="{Binding CanEdit}"
                     IsChecked="{Binding UseShared, Converter={StaticResource InverseBool}}"/>
        <RadioButton GroupName="store" Margin="0,0,0,4"
                     Content="Shared network folder (for multiple stations)"
                     IsEnabled="{Binding CanEdit}"
                     IsChecked="{Binding UseShared}"/>

        <Grid Margin="20,0,0,10" IsEnabled="{Binding CanEditPath}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Padding="4" VerticalContentAlignment="Center"
                     Text="{Binding SharedDir, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="A UNC path is best, e.g. \\server\labels\Data"/>
            <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="8,2"
                    Command="{Binding BrowseCommand}"/>
        </Grid>

        <Border Background="#FFF8E1" BorderBrush="#E6C200" BorderThickness="1" Padding="6" Margin="0,0,0,8"
                Visibility="{Binding IsAdminLocked, Converter={StaticResource BoolToVis}}">
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Text="This location is pinned by appsettings.json or an environment variable, so it can't be changed here."/>
        </Border>

        <TextBlock FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,0,0,4"
                   Text="{Binding EffectiveDataDir, StringFormat=Current location: {0}}"/>
        <TextBlock Text="{Binding Status}" Foreground="#B00020" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Save" Width="80" Command="{Binding SaveCommand}" IsDefault="True"
                    Background="#2196F3" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</Window>
