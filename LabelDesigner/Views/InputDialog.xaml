<Window x:Class="LabelDesigner.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource TenxsWindow}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptBlock" Margin="0,0,0,6" FontWeight="SemiBold"/>
        <TextBox x:Name="ValueBox" Padding="4" Margin="0,0,0,14"
                 KeyDown="ValueBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="70" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Width="70" IsDefault="True" Click="OK_Click"
                   />
        </StackPanel>
    </StackPanel>
</Window>
