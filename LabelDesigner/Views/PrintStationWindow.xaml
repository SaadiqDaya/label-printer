<Window x:Class="LabelDesigner.Views.PrintStationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Label Print Station" Height="740" Width="1160"
        MinHeight="560" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        xmlns:beh="clr-namespace:LabelDesigner.Behaviors">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ── Templates / job queue ─────────────────────────────── -->
        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="Templates">
                <DockPanel Margin="4">
                    <DockPanel DockPanel.Dock="Top" Margin="0,4,0,6">
                        <Button DockPanel.Dock="Right" Content="⟳" Width="30" Margin="6,0,0,0"
                                Command="{Binding RefreshCommand}" ToolTip="Refresh template list"/>
                        <TextBox VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             DisplayMemberPath="Name"/>
                </DockPanel>
            </TabItem>
            <TabItem Header="{Binding JobsHeader}">
                <DockPanel Margin="4">
                    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,6" TextWrapping="Wrap" Foreground="#555" FontSize="11"
                               Text="Jobs dropped into a watch folder wait here until you release them. Auto-print folders print on arrival."/>
                    <ListBox ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Info}" FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding FolderName, StringFormat=folder: {0}}" FontSize="11" Foreground="#999"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- ── Preview + status ──────────────────────────────────── -->
        <DockPanel Grid.Column="1" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="Preview" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
            <Border DockPanel.Dock="Bottom" Background="#F3F3F3" Padding="8" Margin="0,8,0,0" CornerRadius="3">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
            </Border>
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                <Image Source="{Binding Preview}" Stretch="Uniform" Margin="14"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
        </DockPanel>

        <!-- ── Data / inputs / job + print + history ─────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- title -->
                <RowDefinition Height="Auto"/>   <!-- operator + printer + qty -->
                <RowDefinition Height="Auto"/>   <!-- data toolbar -->
                <RowDefinition Height="*"/>      <!-- records OR manual inputs OR job -->
                <RowDefinition Height="Auto"/>   <!-- action buttons -->
                <RowDefinition Height="Auto"/>   <!-- history label -->
                <RowDefinition Height="170"/>    <!-- history -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Print" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Operator" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding OperatorName, UpdateSourceTrigger=LostFocus}"
                           ToolTip="Recorded on every print in the history (who printed it)"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Printer" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                           ItemsSource="{Binding AvailablePrinters}" SelectedItem="{Binding SelectedPrinter}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Quantity" VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="{Binding ShowTemplateActions, Converter={StaticResource BoolToVis}}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                           Visibility="{Binding ShowTemplateActions, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- Data toolbar: which data file is loaded + load/clear (template mode only) -->
            <DockPanel Grid.Row="2" Margin="0,0,0,6"
                       Visibility="{Binding ShowTemplateActions, Converter={StaticResource BoolToVis}}">
                <Button DockPanel.Dock="Right" Content="Load file…" Padding="8,2" Margin="6,0,0,0"
                        Command="{Binding LoadDataFileCommand}"
                        ToolTip="Load today's data file for this run (Excel or CSV, same columns as the template)"/>
                <Button DockPanel.Dock="Right" Content="Manual" Padding="8,2"
                        Command="{Binding ClearDataCommand}" ToolTip="Switch to manual field entry"/>
                <TextBlock Text="{Binding DataSummary}" VerticalAlignment="Center" Foreground="#555"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <!-- Content: data records OR manual inputs OR the selected watch-folder job -->
            <Grid Grid.Row="3">
                <!-- Data-driven: tick rows, override quantities, print a range -->
                <DockPanel Visibility="{Binding ShowData, Converter={StaticResource BoolToVis}}">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Records" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Width="46" Text="{Binding RangeStart, UpdateSourceTrigger=PropertyChanged}" ToolTip="First record"/>
                        <TextBlock Text="to" VerticalAlignment="Center" Margin="6,0"/>
                        <TextBox Width="46" Text="{Binding RangeEnd, UpdateSourceTrigger=PropertyChanged}" ToolTip="Last record"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                        <CheckBox Content="Skip invalid rows (report them)" Margin="0,0,0,6"
                                  IsChecked="{Binding SkipInvalidRows}"
                                  ToolTip="ON: print the valid rows and list the skipped ones. OFF: any bad row blocks the whole batch."/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Print selected" Padding="8,4" Margin="0,0,6,0"
                                    Command="{Binding PrintSelectedCommand}" ToolTip="Print the highlighted record × Quantity"/>
                            <Button Content="Print all in range" Padding="8,4" FontWeight="Bold"
                                    Foreground="White" Background="#2D7D2D" BorderThickness="0"
                                    Command="{Binding PrintAllCommand}"
                                    ToolTip="Print every ticked record in the range at its quantity"/>
                        </StackPanel>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Rows}"
                             SelectedIndex="{Binding SelectedRowIndex, Mode=TwoWay}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Include}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding WasText}" FontSize="10"
                                               Foreground="#B36B00" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <TextBox DockPanel.Dock="Right" Width="38" Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                                             beh:NumericInput.IsEnabled="True" FontSize="11" Padding="1"
                                             VerticalAlignment="Center" HorizontalContentAlignment="Center"
                                             ToolTip="Labels to print for this row"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Manual entry: one input per field. The control matches the field's type —
                     dropdown for allowed-values, date picker for dates, numeric box for numbers,
                     plain text otherwise. Exactly one is visible per field. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ShowManual, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Inputs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding PromptLabel}" FontWeight="SemiBold"/>
                                    <!-- plain text -->
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}"/>
                                    <!-- number: digits only, honours Min/Max at print time -->
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             beh:NumericInput.IsEnabled="True"
                                             Visibility="{Binding IsNumber, Converter={StaticResource BoolToVis}}"/>
                                    <!-- date: calendar picker -->
                                    <DatePicker SelectedDate="{Binding DateValue, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding IsDate, Converter={StaticResource BoolToVis}}"/>
                                    <!-- allowed values: editable dropdown -->
                                    <ComboBox IsEditable="True" ItemsSource="{Binding AllowedValues}"
                                              Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                              Visibility="{Binding HasChoices, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Watch-folder job: rows grouped per routed template; tick + override, then release -->
                <DockPanel Visibility="{Binding JobMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="PRINT JOB" Padding="14,6" FontWeight="Bold" Margin="0,0,6,0"
                                    Foreground="White" Background="#2D7D2D" BorderThickness="0"
                                    Command="{Binding PrintJobCommand}"
                                    ToolTip="Print every ticked row (each group goes to its template's printer)"/>
                            <Button Content="Reject" Padding="10,6" Margin="0,0,6,0"
                                    Command="{Binding RejectJobCommand}"
                                    ToolTip="Move the job file to the failed folder without printing"/>
                            <Button Content="Close" Padding="10,6"
                                    Command="{Binding CloseJobCommand}"
                                    ToolTip="Leave the job in the queue and go back to templates"/>
                        </StackPanel>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#FDECEA" BorderBrush="#D9534F" BorderThickness="1" Padding="6" Margin="0,0,0,6"
                                    Visibility="{Binding SelectedJob.HasProblems, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <StackPanel>
                                    <TextBlock Text="Rows that cannot print (no template):" FontWeight="SemiBold" Foreground="#B71C1C"/>
                                    <ItemsControl ItemsSource="{Binding SelectedJob.Problems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#B71C1C" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding SelectedJob.Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">
                                            <DockPanel Margin="0,0,0,2">
                                                <TextBlock Text="{Binding TemplateName}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding PrinterText, StringFormat= →  {0}}" Foreground="#666" FontSize="11"
                                                           VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                            </DockPanel>
                                            <ListBox ItemsSource="{Binding Rows}" MaxHeight="220"
                                                     HorizontalContentAlignment="Stretch"
                                                     SelectedItem="{Binding DataContext.JobPreviewRow, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWayToSource}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel LastChildFill="True"
                                                                   ToolTip="{Binding Error}">
                                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Include}"
                                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding WasText}" FontSize="10"
                                                                       Foreground="#B36B00" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                            <TextBox DockPanel.Dock="Right" Width="38"
                                                                     Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                                                                     beh:NumericInput.IsEnabled="True" FontSize="11" Padding="1"
                                                                     VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                                                            <TextBlock DockPanel.Dock="Right" Text="⚠" Foreground="#D9534F" Margin="4,0"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <!-- Action buttons (template mode) -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0"
                        Visibility="{Binding ShowTemplateActions, Converter={StaticResource BoolToVis}}">
                <Button Content="PRINT" Width="120" Height="40" FontSize="15" FontWeight="Bold"
                        Foreground="White" Background="#2D7D2D" BorderThickness="0" Margin="0,0,8,0"
                        Command="{Binding PrintCommand}"
                        Visibility="{Binding ShowManual, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Test print 1" Height="40" Padding="12,0" Margin="0,0,8,0"
                        Command="{Binding TestPrintCommand}"
                        ToolTip="Print one proof label without using a serial number"/>
                <Button Content="Export ZPL" Height="40" Padding="12,0"
                        Command="{Binding ExportZplCommand}"
                        ToolTip="Save the native ZPL for the current label (inspect without a Zebra)"/>
            </StackPanel>

            <!-- History -->
            <DockPanel Grid.Row="5" Margin="0,12,0,4">
                <Button DockPanel.Dock="Right" Content="Export CSV" Padding="8,2"
                        Command="{Binding ExportHistoryCommand}" ToolTip="Export the full print history for audit/reconciliation"/>
                <TextBlock Text="Recent prints — Reprint repeats the original IDs" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>
            <ListBox Grid.Row="6" ItemsSource="{Binding History}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Reprint" Padding="8,2" Margin="6,0,0,0"
                                    Command="{Binding DataContext.ReprintCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                            <TextBlock Text="{Binding Display}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
