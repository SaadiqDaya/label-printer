<Window x:Class="LabelDesigner.Views.ExcelImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Print from Excel"
        Width="700" Height="520"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Top: file + template selection -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Excel file:" VerticalAlignment="Center" Grid.Row="0"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}" IsReadOnly="True"
                     Padding="4,3" Margin="0,0,4,0"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Width="72" Padding="6,3"
                    Command="{Binding BrowseFileCommand}"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Reload" Width="60" Padding="6,3" Margin="4,0,0,0"
                    Command="{Binding LoadFileCommand}"/>

            <TextBlock Text="Template:" VerticalAlignment="Center" Grid.Row="1" Margin="0,6,0,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,4,0"
                      ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate}"
                      DisplayMemberPath="Name"/>
            <CheckBox Grid.Row="1" Grid.Column="3" Margin="4,6,0,0"
                      Content="Preview" IsChecked="{Binding ShowPreview}"
                      VerticalAlignment="Center"/>
        </Grid>

        <!-- Bottom: status + buttons -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#555" FontStyle="Italic" Margin="0,0,0,6"
                       TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Select All"      Width="80" Margin="0,0,6,0" Command="{Binding SelectAllCommand}"/>
                <Button Content="Select None"     Width="80" Margin="0,0,6,0" Command="{Binding SelectNoneCommand}"/>
                <Button Content="Print Selected"  Width="110" Margin="0,0,6,0" IsDefault="True"
                        Command="{Binding PrintSelectedCommand}"
                        Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                <Button Content="Close" Width="70" IsCancel="True" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Row list — dynamic display; columns are generic to work with any template -->
        <ListView ItemsSource="{Binding Rows}" SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <!-- Checkbox -->
                    <GridViewColumn Width="34">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Primary display: first two field values -->
                    <GridViewColumn Header="Row Data" Width="340">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Display}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Summary}" Foreground="#777" FontSize="10"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Print quantity -->
                    <GridViewColumn Header="Print#" Width="54"
                                    DisplayMemberBinding="{Binding PrintQty}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
