<Window x:Class="LabelDesigner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LabelDesigner.ViewModels"
        xmlns:local="clr-namespace:LabelDesigner.Views"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Label Designer" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVisibility" />
        <conv:NullToVisibilityConverter    x:Key="NullToVisibility" />
    </Window.Resources>

    <DockPanel>
        <!-- ── Menu ─────────────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Template..."   Command="{Binding NewCommand}"    InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..."           Command="{Binding OpenCommand}"   InputGestureText="Ctrl+O" />
                <Separator/>
                <MenuItem Header="_Save"              Command="{Binding SaveCommand}"   InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..."        Command="{Binding SaveAsCommand}" />
                <Separator/>
                <MenuItem Header="Open Print _Station" Command="{Binding OpenPrintStationCommand}" />
                <MenuItem Header="Settings..." Command="{Binding OpenSettingsCommand}" />
                <Separator/>
                <MenuItem Header="Recent _Templates" ItemsSource="{Binding RecentFileItems}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header"  Value="{Binding Name}"/>
                            <Setter Property="Command" Value="{Binding OpenCommand}"/>
                            <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Import from _BarTender (.btw)…" Command="{Binding ImportFromBarTenderCommand}" />
                <MenuItem Header="_Export">
                    <MenuItem Header="Label as P_NG…" Command="{Binding ExportPngCommand}"
                              ToolTip="Renders the label (current preview data) to a PNG at the template's DPI"/>
                    <MenuItem Header="Label as P_DF…" Command="{Binding ExportPdfCommand}"
                              ToolTip="One-page PDF at the exact label size — pixel-identical to the print preview"/>
                    <MenuItem Header="Label as _ZPL…" Command="{Binding ExportZplCommand}"
                              ToolTip="Native ZPL II commands for inspection or sending to a Zebra"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"           Command="{Binding Designer.UndoCommand}"  InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo"           Command="{Binding Designer.RedoCommand}"  InputGestureText="Ctrl+Y" />
                <Separator/>
                <MenuItem Header="_Copy Element"   Command="{Binding Designer.CopyCommand}"  InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste Element"  Command="{Binding Designer.PasteCommand}" InputGestureText="Ctrl+V" />
                <Separator/>
                <MenuItem Header="_Delete Element" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del" />
            </MenuItem>
            <MenuItem Header="_Arrange">
                <MenuItem Header="_Duplicate"            Command="{Binding Designer.DuplicateCommand}"   InputGestureText="Ctrl+D"/>
                <Separator/>
                <MenuItem Header="_Group"                Command="{Binding Designer.GroupCommand}"       InputGestureText="Ctrl+G"
                          ToolTip="Selected elements select and move as one (saved with the template)"/>
                <MenuItem Header="_Ungroup"              Command="{Binding Designer.UngroupCommand}"     InputGestureText="Ctrl+Shift+G"/>
                <Separator/>
                <MenuItem Header="Align _Left"           Command="{Binding Designer.AlignLeftCommand}"/>
                <MenuItem Header="Align _Right"          Command="{Binding Designer.AlignRightCommand}"/>
                <MenuItem Header="Align _Top"            Command="{Binding Designer.AlignTopCommand}"/>
                <MenuItem Header="Align _Bottom"         Command="{Binding Designer.AlignBottomCommand}"/>
                <MenuItem Header="Center _Horizontally"  Command="{Binding Designer.AlignCenterHCommand}"/>
                <MenuItem Header="Center _Vertically"    Command="{Binding Designer.AlignCenterVCommand}"/>
                <Separator/>
                <MenuItem Header="Distribute Hori_zontally" Command="{Binding Designer.DistributeHCommand}"/>
                <MenuItem Header="Distribute Vertica_lly"   Command="{Binding Designer.DistributeVCommand}"/>
                <Separator/>
                <MenuItem Header="Bring to _Front"       Command="{Binding Designer.BringToFrontCommand}"/>
                <MenuItem Header="Send to Bac_k"         Command="{Binding Designer.SendToBackCommand}"/>
            </MenuItem>
            <MenuItem Header="_Template">
                <MenuItem Header="_Manage Fields / Excel Mapping…" Command="{Binding ManageFieldsCommand}" InputGestureText="Ctrl+M" />
                <MenuItem Header="_Resize Canvas…"                 Command="{Binding ResizeCanvasCommand}" />
                <Separator/>
                <MenuItem Header="Template Rou_ting (data → template)…" Command="{Binding OpenTemplateRoutingCommand}"
                          ToolTip="Rules that pick which template a batch row prints with (used by watch-folder jobs)"/>
            </MenuItem>
        </Menu>

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top" Height="38">
            <Button ToolTip="New Template"  Command="{Binding NewCommand}"        Padding="6,2">New</Button>
            <Button ToolTip="Open Template" Command="{Binding OpenCommand}"       Padding="6,2">Open</Button>
            <Button ToolTip="Save Template" Command="{Binding SaveCommand}"       Padding="6,2">Save</Button>
            <Separator/>
            <Button ToolTip="Undo (Ctrl+Z)" Command="{Binding Designer.UndoCommand}" Padding="6,2">↩ Undo</Button>
            <Button ToolTip="Redo (Ctrl+Y)" Command="{Binding Designer.RedoCommand}" Padding="6,2">↪ Redo</Button>
            <Separator/>
            <Button ToolTip="Add Text"      Command="{Binding AddTextCommand}"      Padding="6,2" Background="#DDEFFF">T Text</Button>
            <Button ToolTip="Add Barcode"   Command="{Binding AddBarcodeCommand}"   Padding="6,2" Background="#DDEFFF">Barcode</Button>
            <Button ToolTip="Add Image"     Command="{Binding AddImageCommand}"     Padding="6,2" Background="#DDEFFF">Image</Button>
            <Button ToolTip="Add Rectangle" Command="{Binding AddRectangleCommand}" Padding="6,2" Background="#DDEFFF">Rect</Button>
            <ToggleButton ToolTip="Draw Line — click then drag on the canvas to place"
                          Command="{Binding AddLineCommand}"
                          IsChecked="{Binding Designer.IsLineDrawMode, Mode=OneWay}"
                          Padding="6,2" Background="#DDEFFF">Line ✏</ToggleButton>
            <Button ToolTip="Add Table"     Command="{Binding AddTableCommand}"     Padding="6,2" Background="#DDEFFF">Table</Button>
            <Separator/>
            <Button ToolTip="Delete selected (Del)" Command="{Binding DeleteSelectedCommand}" Padding="6,2" Background="#FFDDDD">Delete</Button>
            <Separator/>
            <ToggleButton ToolTip="Smart alignment guides — snap to other elements' edges/centres while dragging"
                          IsChecked="{Binding Designer.SmartGuides}"
                          Padding="6,2">Guides</ToggleButton>
            <ToggleButton ToolTip="Snap elements to grid when dragging"
                          IsChecked="{Binding Designer.SnapToGrid}"
                          Padding="6,2">Snap</ToggleButton>
            <TextBox Width="34" Padding="3,2" Margin="2,0,0,0" VerticalContentAlignment="Center"
                     Text="{Binding Designer.GridSize, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Grid size in pixels"
                     Visibility="{Binding Designer.SnapToGrid, Converter={StaticResource BoolToVisibility}}"/>
            <Separator/>
            <Button ToolTip="Print (Ctrl+P)" Command="{Binding PrintCommand}" Padding="6,2" FontWeight="Bold">Print...</Button>
            <Separator/>
            <Button ToolTip="Create a blank template sized from a BarTender .btw file"
                    Command="{Binding ImportFromBarTenderCommand}"
                    Padding="6,2" Background="#FFF3E0" FontWeight="SemiBold">BTW Import...</Button>
        </ToolBar>

        <!-- ── Status bar ───────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <StatusBarItem><Separator/></StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding Designer.CurrentFilePath}" Foreground="#888" FontSize="10"/>
            </StatusBarItem>
            <StatusBarItem><Separator/></StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding IpcStatus}" Foreground="#2196F3" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main three-column layout ─────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" MinWidth="140" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="230" MinWidth="180" />
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: Elements / Layers / Data tabs ── -->
            <TabControl Grid.Column="0" Margin="4">

                <!-- Elements tab -->
                <TabItem Header="Elements">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="10" Foreground="#888"
                                   Text="Click to select on canvas" Margin="4,4,4,2"/>
                        <ListBox ItemsSource="{Binding Designer.Elements}"
                                 SelectedItem="{Binding Designer.SelectedElement}"
                                 SelectionChanged="ElementList_SelectionChanged"
                                 PreviewMouseRightButtonDown="ElementList_RightClick">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Move Forward (↑ Z)"
                                              Command="{Binding PlacementTarget.DataContext.Designer.MoveElementForwardCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Move Backward (↓ Z)"
                                              Command="{Binding PlacementTarget.DataContext.Designer.MoveElementBackwardCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.DataContext.DeleteSelectedCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Foreground="#C00"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <ComboBox DockPanel.Dock="Right" Width="65" Margin="4,0,0,0"
                                                  FontSize="10" VerticalAlignment="Center"
                                                  ItemsSource="{Binding AvailableLayers}"
                                                  DisplayMemberPath="Name"
                                                  SelectedItem="{Binding SelectedLayer}"
                                                  ToolTip="Layer assignment"/>
                                        <TextBlock DockPanel.Dock="Left" Text="🔒" FontSize="10" Margin="0,0,2,0"
                                                   VerticalAlignment="Center" ToolTip="Locked"
                                                   Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                   Margin="2,0" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=OneWay}"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </TabItem>

                <!-- Layers tab -->
                <TabItem Header="Layers">
                    <DockPanel DataContext="{Binding Designer}">
                        <!-- Toolbar -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                            <Button Content="+ Add"  Padding="8,2" Margin="0,0,4,0"
                                    Command="{Binding AddLayerCommand}"
                                    ToolTip="Add a new layer"/>
                            <Button Content="Delete" Padding="8,2" Margin="0,0,4,0"
                                    Command="{Binding DeleteLayerCommand}"
                                    Foreground="#C00" ToolTip="Delete selected layer"/>
                            <Button Content="↑" Padding="6,2" Margin="0,0,2,0"
                                    Command="{Binding MoveLayerUpCommand}"/>
                            <Button Content="↓" Padding="6,2"
                                    Command="{Binding MoveLayerDownCommand}"/>
                        </StackPanel>

                        <!-- Layer list (top of list = frontmost in print) -->
                        <ListBox DockPanel.Dock="Top" MaxHeight="130"
                                 ItemsSource="{Binding Layers}"
                                 SelectedItem="{Binding SelectedLayer}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <ToggleButton DockPanel.Dock="Right" Width="22" Height="18"
                                                      Content="✕" FontSize="9" Margin="2,0,0,0"
                                                      IsChecked="{Binding IsHidden}"
                                                      ToolTip="Hide layer completely in designer"
                                                      Padding="0"
                                                      Background="Transparent" BorderThickness="1"/>
                                        <CheckBox DockPanel.Dock="Left"
                                                  IsChecked="{Binding IsVisible}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,4,0"
                                                  ToolTip="Dim layer elements (25% opacity) — uncheck to dim"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Selected layer properties -->
                        <GroupBox DockPanel.Dock="Top" Margin="4,4,4,0" Padding="4"
                                  Header="Selected Layer"
                                  DataContext="{Binding SelectedLayer}"
                                  Visibility="{Binding Converter={StaticResource NullToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Name" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,4" Padding="3,2"/>

                                <TextBlock Text="Print Condition" FontSize="10" Foreground="#555" Margin="0,4,0,1"/>
                                <!-- Condition builder row -->
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="LayerCondFieldPicker" Grid.Column="0"
                                              ItemsSource="{Binding AvailableFields}"
                                              FontSize="10" Height="22"
                                              ToolTip="Field to test"/>
                                    <ComboBox x:Name="LayerCondOpPicker" Grid.Column="1" Margin="2,0"
                                              FontSize="10" Height="22" SelectedIndex="0">
                                        <ComboBoxItem>==</ComboBoxItem>
                                        <ComboBoxItem>!=</ComboBoxItem>
                                        <ComboBoxItem>&gt;</ComboBoxItem>
                                        <ComboBoxItem>&gt;=</ComboBoxItem>
                                        <ComboBoxItem>&lt;</ComboBoxItem>
                                        <ComboBoxItem>&lt;=</ComboBoxItem>
                                        <ComboBoxItem>set</ComboBoxItem>
                                        <ComboBoxItem>empty</ComboBoxItem>
                                    </ComboBox>
                                    <TextBox x:Name="LayerCondValueBox" Grid.Column="2" Margin="0,2,0,2"
                                             FontSize="10" Height="22"
                                             ToolTip="Comparison value"/>
                                    <Button Grid.Column="3" Content="↵ Add" Margin="2,2,0,2"
                                            FontSize="9" Height="22"
                                            Click="LayerInsertCondition_Click"/>
                                </Grid>
                                <!-- Condition list -->
                                <ListView ItemsSource="{Binding ConditionList}" MaxHeight="70" Margin="0,0,0,2"
                                          BorderThickness="1" BorderBrush="#CCC">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="✕" Width="18" Height="16"
                                                        Click="LayerRemoveCondition_Click"
                                                        Tag="{Binding}" Padding="0" FontSize="9"
                                                        Background="Transparent"/>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                                           FontSize="10" TextWrapping="Wrap"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Text="Leave blank to always print this layer."
                                           FontSize="9" Foreground="#999" FontStyle="Italic" Margin="0,2,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Top of list = frontmost layer. Assign elements via Properties panel."
                                   FontSize="10" Foreground="#888" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="6,8,6,4"/>
                    </DockPanel>
                </TabItem>

                <!-- Data Sources tab -->
                <TabItem Header="Data">
                    <DockPanel DataContext="{Binding Designer}">
                        <!-- Toolbar -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                            <Button Content="+ Add" Padding="8,2" Margin="0,0,4,0"
                                    Command="{Binding AddDataSourceCommand}"
                                    ToolTip="Add a computed data source (date, time, serial, fixed…)"/>
                            <Button Content="Delete" Padding="8,2" Foreground="#C00"
                                    Command="{Binding RemoveDataSourceCommand}"
                                    ToolTip="Remove selected data source"/>
                        </StackPanel>

                        <!-- Data source list -->
                        <ListBox DockPanel.Dock="Top" MaxHeight="110"
                                 ItemsSource="{Binding DataSources}"
                                 SelectedItem="{Binding SelectedDataSource}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" Margin="2,1"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Selected source properties -->
                        <GroupBox DockPanel.Dock="Top" Margin="4,4,4,0" Padding="4"
                                  Header="Selected Source"
                                  DataContext="{Binding SelectedDataSource}"
                                  Visibility="{Binding Converter={StaticResource NullToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Field Name" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="3,2" Margin="0,0,0,4"
                                         ToolTip="Use this name as the Bound Field in text/barcode elements"/>

                                <TextBlock Text="Type" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <ComboBox SelectedItem="{Binding Type}"
                                          ItemsSource="{Binding Source={x:Static vm:DataSourceViewModel.AllTypes}}"
                                          Margin="0,0,0,4"/>

                                <!-- Source Column (only for DatabaseField) -->
                                <TextBlock Text="Source Column" FontSize="10" Foreground="#555" Margin="0,0,0,1"
                                           Visibility="{Binding IsDatabaseField, Converter={StaticResource BoolToVisibility}}"/>
                                <ComboBox IsEditable="True" Margin="0,0,0,2"
                                          Visibility="{Binding IsDatabaseField, Converter={StaticResource BoolToVisibility}}"
                                          ItemsSource="{Binding DataContext.Designer.Template.Fields, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Text="{Binding SourceField, UpdateSourceTrigger=LostFocus}"
                                          ToolTip="The data-file column this source mirrors. Re-point it here when the file changes — every element bound to this source follows."/>
                                <TextBlock FontSize="9" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,4"
                                           Visibility="{Binding IsDatabaseField, Converter={StaticResource BoolToVisibility}}"
                                           Text="Bind elements to THIS source's name instead of the raw column. If the data file's column changes, fix it once here."/>

                                <!-- Fixed Value input (only shown when Type = FixedValue) -->
                                <TextBlock Text="Fixed Value" FontSize="10" Foreground="#555" Margin="0,0,0,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="FixedValue">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding FixedValue, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="3,2" Margin="0,0,0,4"
                                         ToolTip="This exact text is always output for this field">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="FixedValue">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock Text="Formula" FontSize="10" Foreground="#555" Margin="0,0,0,1"
                                           Visibility="{Binding IsFormula, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBox Text="{Binding FormulaExpression, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="3,2" Margin="0,0,0,2" MinHeight="38" TextWrapping="Wrap"
                                         Visibility="{Binding IsFormula, Converter={StaticResource BoolToVisibility}}"
                                         ToolTip="e.g. UPPER({sku}) &amp; &quot;-&quot; &amp; {lot}   |   {qty} * {price}   |   LEFT({code},3)"/>
                                <TextBlock FontSize="9" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,4"
                                           Visibility="{Binding IsFormula, Converter={StaticResource BoolToVisibility}}"
                                           Text="{}{Field} refs · &quot;text&quot; · &amp; concat · + - * / math · UPPER/LOWER/TRIM/LEFT/RIGHT/MID/CONCAT/ROUND"/>

                                <TextBlock Text="Format" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding Format, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="3,2" Margin="0,0,0,4"
                                         ToolTip="C# format: dd/MM/yyyy  HH:mm  D4  etc."/>

                                <TextBlock Text="+ Months (RelativeDate)" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding RelativeMonths, UpdateSourceTrigger=LostFocus}"
                                         Padding="3,2" Margin="0,0,0,4"/>

                                <TextBlock Text="+ Days (RelativeDate)" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding RelativeDays, UpdateSourceTrigger=LostFocus}"
                                         Padding="3,2" Margin="0,0,0,4"/>

                                <TextBlock Text="Start Value (Serial)" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding SerialStart, UpdateSourceTrigger=LostFocus}"
                                         Padding="3,2"/>

                                <TextBlock Text="Increment (Serial)" FontSize="10" Foreground="#555" Margin="0,4,0,1"
                                           Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBox Text="{Binding Increment, UpdateSourceTrigger=LostFocus}" Padding="3,2"
                                         Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}"
                                         ToolTip="Amount added to the serial for each label"/>

                                <TextBlock Text="Serial behaviour" FontSize="10" Foreground="#555" Margin="0,4,0,1"
                                           Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}"/>
                                <ComboBox SelectedItem="{Binding SerialMode}"
                                          ItemsSource="{Binding Source={x:Static vm:DataSourceViewModel.AllSerialModes}}"
                                          Margin="0,0,0,2"
                                          Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}"
                                          ToolTip="Continuous = keeps counting across jobs (needs a stable store; share it for multiple stations). ResetPerBatch = starts at the Start Value every job."/>
                                <TextBlock FontSize="9" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,4"
                                           Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}"
                                           Text="Continuous needs a shared folder for multiple stations (File ▸ Settings). ResetPerBatch needs none."/>

                                <Grid Margin="0,2,0,0" Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Prefix" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                        <TextBox Text="{Binding SerialPrefix, UpdateSourceTrigger=PropertyChanged}" Padding="3,2"
                                                 ToolTip="e.g. CTN-"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Suffix" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                        <TextBox Text="{Binding SerialSuffix, UpdateSourceTrigger=PropertyChanged}" Padding="3,2"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,2,0,0" Visibility="{Binding IsSerial, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" Content="Alphanumeric (0-9 A-Z)" VerticalAlignment="Center"
                                              IsChecked="{Binding SerialAlphanumeric}"
                                              ToolTip="Base-36 counter, e.g. 0001 → 000Z → 0010"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Pad width" FontSize="10" Foreground="#555" Margin="0,0,0,1"/>
                                        <TextBox Width="50" Text="{Binding SerialPadWidth, UpdateSourceTrigger=LostFocus}" Padding="3,2"
                                                 ToolTip="Zero-pad width for alphanumeric serials"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Bind elements to these field names via Bound Field in the Properties panel."
                                   FontSize="10" Foreground="#888" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="6,8,6,4"/>
                    </DockPanel>
                </TabItem>

            </TabControl>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDDDDD" />

            <!-- ── Designer canvas ── -->
            <local:DesignerView Grid.Column="2"
                                x:Name="DesignerView"
                                DataContext="{Binding Designer}" />

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#DDDDDD" />

            <!-- ── Properties panel ── -->
            <local:PropertiesPanel Grid.Column="4"
                                   DataContext="{Binding Designer.SelectedElement}" />
        </Grid>
    </DockPanel>
</Window>
