<Window x:Class="LabelDesigner.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="{Binding Title}" Width="780" Height="740"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibility"/>
        <conv:InverseBoolConverter              x:Key="InverseBool"/>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- ── Print options ──────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">

            <!-- Printer selection -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Printer:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailablePrinters}"
                          SelectedItem="{Binding SelectedPrinter}"
                          IsEditable="True"/>
            </Grid>

            <!-- Sheet mode: layout info + where to start on a part-used sheet -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding IsSheetTemplate, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding SheetInfo}" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                <TextBlock Text="Start at label #" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <TextBox Width="44" Padding="3,2"
                         Text="{Binding StartLabelNumber, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Cell where printing starts on the FIRST sheet — use up a part-used Avery sheet (1 = top-left)"/>
            </StackPanel>

            <!-- Print scope: this record vs. all loaded records -->
            <StackPanel Margin="0,0,0,10"
                        Visibility="{Binding HasAllRecords, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Scope:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <RadioButton IsChecked="{Binding PrintAllRecords}" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Print all records ("/>
                        <TextBlock Text="{Binding AllRecordsCount}" FontWeight="Bold"/>
                        <TextBlock Text=" rows = "/>
                        <TextBlock Text="{Binding AllRecordsTotalLabels}" FontWeight="Bold"/>
                        <TextBlock Text=" labels)"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton IsChecked="{Binding PrintAllRecords, Converter={StaticResource InverseBool}}">
                    <TextBlock Text="Print this record only"/>
                </RadioButton>
            </StackPanel>

            <!-- Quantity (disabled when 'Print all records' is selected) -->
            <StackPanel Margin="0,0,0,10"
                        IsEnabled="{Binding PrintAllRecords, Converter={StaticResource InverseBool}}">
                <TextBlock Text="Quantity:" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <!-- Row 1: from-data option (shown only when a data qty was supplied) -->
                <RadioButton IsChecked="{Binding UseDataQty}"
                             Margin="0,0,0,4"
                             Visibility="{Binding HasDataQty, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Use data quantity: "/>
                        <TextBlock Text="{Binding DataQty}" FontWeight="Bold"/>
                    </StackPanel>
                </RadioButton>

                <!-- Row 2: manual qty -->
                <StackPanel Orientation="Horizontal">
                    <RadioButton IsChecked="{Binding UseManualQty}"
                                 Margin="0,0,6,0"
                                 Visibility="{Binding HasDataQty, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Copies: " VerticalAlignment="Center"/>
                    <TextBox Width="52" Padding="3,2"
                             Text="{Binding ManualQty, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding UseDataQty, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="{Binding PrintButtonLabel}"
                        MinWidth="160" IsDefault="True"
                        Command="{Binding PrintCommand}"
                        Background="#2196F3" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Zoom toolbar + job navigation ──────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="−" Width="28" FontSize="14" Padding="0"
                        Click="ZoomOut_Click" ToolTip="Zoom out (−)"/>
                <TextBlock Text="{Binding PreviewZoomLabel}"
                           Width="44" TextAlignment="Center"
                           VerticalAlignment="Center" FontSize="12" Margin="2,0"/>
                <Button Content="+" Width="28" FontSize="14" Padding="0"
                        Click="ZoomIn_Click" ToolTip="Zoom in (+)"/>
                <Button Content="Fit" Width="40" Margin="8,0,0,0" Padding="4,2"
                        Click="Fit_Click" ToolTip="Scale the preview to fill this pane"/>
                <Button Content="1:1" Width="40" Margin="4,0,0,0" Padding="4,2"
                        Click="Actual_Click" ToolTip="Show at actual size (100%)"/>
            </StackPanel>

            <!-- Step through every record that will actually print (all-records mode) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Visibility="{Binding HasAllRecords, Converter={StaticResource BoolToVisibility}}">
                <Button Content="◄" Width="28" Padding="0"
                        Command="{Binding PrevLabelCommand}" ToolTip="Previous record in the job"/>
                <TextBlock Text="{Binding PreviewInfo}" VerticalAlignment="Center"
                           FontSize="11" Margin="6,0" MinWidth="170" TextAlignment="Center"/>
                <Button Content="►" Width="28" Padding="0"
                        Command="{Binding NextLabelCommand}" ToolTip="Next record in the job"/>
            </StackPanel>
        </DockPanel>

        <!-- ── Job list (left) + preview image (right) ─────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Every record that will print: thumbnail left, quantity right. Click = preview it. -->
            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,6,0"
                    Visibility="{Binding ShowJobList, Converter={StaticResource BoolToVisibility}}">
                <ListBox Width="190"
                         ItemsSource="{Binding JobItems}"
                         SelectedItem="{Binding SelectedJobItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,2">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Caption}"
                                           Width="22" FontSize="10" Foreground="#888"
                                           VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding QtyText}"
                                           FontWeight="Bold" FontSize="12" Margin="6,0,2,0"
                                           VerticalAlignment="Center"
                                           ToolTip="Labels printed for this record"/>
                                <Border BorderBrush="#DDD" BorderThickness="1" Background="White">
                                    <Image Source="{Binding Thumbnail}" Height="40" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1" Background="#888">
                <ScrollViewer x:Name="PreviewScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Image x:Name="PreviewImage"
                           Margin="12"
                           Stretch="Fill"
                           Source="{Binding PreviewImage}"
                           Width="{Binding PreviewDisplayWidth}"
                           Height="{Binding PreviewDisplayHeight}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.LayoutTransform>
                            <ScaleTransform
                                ScaleX="{Binding DataContext.PreviewZoom, RelativeSource={RelativeSource AncestorType=Window}}"
                                ScaleY="{Binding DataContext.PreviewZoom, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>
            </Border>
        </Grid>

    </DockPanel>
</Window>
