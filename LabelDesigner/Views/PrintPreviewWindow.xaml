<Window x:Class="LabelDesigner.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="{Binding Title}" Width="620" Height="740"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibility"/>
        <conv:InverseBoolConverter              x:Key="InverseBool"/>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- ── Print options ──────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">

            <!-- Printer selection -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Printer:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailablePrinters}"
                          SelectedItem="{Binding SelectedPrinter}"
                          IsEditable="True"/>
            </Grid>

            <!-- Print scope: this record vs. all loaded records -->
            <StackPanel Margin="0,0,0,10"
                        Visibility="{Binding HasAllRecords, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Scope:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <RadioButton IsChecked="{Binding PrintAllRecords}" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Print all records ("/>
                        <TextBlock Text="{Binding AllRecordsCount}" FontWeight="Bold"/>
                        <TextBlock Text=" rows = "/>
                        <TextBlock Text="{Binding AllRecordsTotalLabels}" FontWeight="Bold"/>
                        <TextBlock Text=" labels)"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton IsChecked="{Binding PrintAllRecords, Converter={StaticResource InverseBool}}">
                    <TextBlock Text="Print this record only"/>
                </RadioButton>
            </StackPanel>

            <!-- Quantity (disabled when 'Print all records' is selected) -->
            <StackPanel Margin="0,0,0,10"
                        IsEnabled="{Binding PrintAllRecords, Converter={StaticResource InverseBool}}">
                <TextBlock Text="Quantity:" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <!-- Row 1: from-data option (shown only when a data qty was supplied) -->
                <RadioButton IsChecked="{Binding UseDataQty}"
                             Margin="0,0,0,4"
                             Visibility="{Binding HasDataQty, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Use data quantity: "/>
                        <TextBlock Text="{Binding DataQty}" FontWeight="Bold"/>
                    </StackPanel>
                </RadioButton>

                <!-- Row 2: manual qty -->
                <StackPanel Orientation="Horizontal">
                    <RadioButton IsChecked="{Binding UseManualQty}"
                                 Margin="0,0,6,0"
                                 Visibility="{Binding HasDataQty, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Copies: " VerticalAlignment="Center"/>
                    <TextBox Width="52" Padding="3,2"
                             Text="{Binding ManualQty, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding UseDataQty, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="{Binding PrintButtonLabel}"
                        MinWidth="160" IsDefault="True"
                        Command="{Binding PrintCommand}"
                        Background="#2196F3" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Zoom toolbar + job navigation ──────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="−" Width="28" FontSize="14" Padding="0"
                        Command="{Binding ZoomOutCommand}" ToolTip="Zoom out (−)"/>
                <TextBlock Text="{Binding PreviewZoomLabel}"
                           Width="44" TextAlignment="Center"
                           VerticalAlignment="Center" FontSize="12" Margin="2,0"/>
                <Button Content="+" Width="28" FontSize="14" Padding="0"
                        Command="{Binding ZoomInCommand}" ToolTip="Zoom in (+)"/>
                <Button Content="1:1" Width="36" Margin="8,0,0,0" Padding="4,2"
                        Command="{Binding ZoomResetCommand}" ToolTip="Reset to 100%"/>
            </StackPanel>

            <!-- Step through every record that will actually print (all-records mode) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Visibility="{Binding HasAllRecords, Converter={StaticResource BoolToVisibility}}">
                <Button Content="◄" Width="28" Padding="0"
                        Command="{Binding PrevLabelCommand}" ToolTip="Previous record in the job"/>
                <TextBlock Text="{Binding PreviewInfo}" VerticalAlignment="Center"
                           FontSize="11" Margin="6,0" MinWidth="170" TextAlignment="Center"/>
                <Button Content="►" Width="28" Padding="0"
                        Command="{Binding NextLabelCommand}" ToolTip="Next record in the job"/>
            </StackPanel>
        </DockPanel>

        <!-- ── Preview image ──────────────────────────────────────────── -->
        <Border BorderBrush="#CCC" BorderThickness="1" Background="#888">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="PreviewImage"
                       Margin="12"
                       Stretch="Fill"
                       Source="{Binding PreviewImage}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.LayoutTransform>
                        <ScaleTransform
                            ScaleX="{Binding DataContext.PreviewZoom, RelativeSource={RelativeSource AncestorType=Window}}"
                            ScaleY="{Binding DataContext.PreviewZoom, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>
        </Border>

    </DockPanel>
</Window>
