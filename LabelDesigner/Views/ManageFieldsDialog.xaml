<Window x:Class="LabelDesigner.Views.ManageFieldsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Manage Fields &amp; Excel Mapping"
        Width="600" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Template name header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding TemplateName, StringFormat='Template: {0}'}"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,14"/>

        <!-- ── Excel source file ── -->
        <TextBlock DockPanel.Dock="Top" Text="Excel Source File" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding ExcelPath}" IsReadOnly="True" Padding="4,3"
                     ToolTip="Excel file used when importing data for this template"/>
            <Button Grid.Column="1" Content="Browse…" Padding="8,3" Margin="4,0,4,0"
                    Command="{Binding BrowseExcelCommand}"/>
            <Button Grid.Column="2" Content="Auto Map"
                    Padding="8,3" FontWeight="SemiBold"
                    Background="#E3F2FD" Command="{Binding AutoMapCommand}"
                    ToolTip="Match field names to Excel column headers automatically"/>
        </Grid>

        <!-- ── Field → Column mapping DataGrid ── -->
        <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,4">
            Field → Excel Column
            <Run Foreground="#888" FontSize="11" FontWeight="Normal"> — select from dropdown or type a column letter</Run>
        </TextBlock>

        <DataGrid DockPanel.Dock="Top" Height="210" Margin="0,0,0,6"
                  ItemsSource="{Binding Mappings}"
                  SelectedItem="{Binding SelectedMapping}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>

                <!-- Field name (read-only display) -->
                <DataGridTextColumn Header="Field Name" Width="*"
                                    Binding="{Binding FieldName}"
                                    IsReadOnly="True"/>

                <!-- Excel Column — dropdown from loaded headers, still editable for manual entry -->
                <DataGridTemplateColumn Header="Excel Column" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ExcelColumn}" Padding="4,2" FontFamily="Consolas"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox IsEditable="True"
                                      ItemsSource="{Binding DataContext.AvailableHeaders,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Letter"
                                      Text="{Binding ExcelColumn, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="ToolTip"  Value="{Binding Header}"/>
                                        <Setter Property="Content"  Value="{Binding Display}"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Test Value -->
                <DataGridTextColumn Width="*"
                                    Binding="{Binding TestValue, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Test Value"
                                   ToolTip="Sample value shown in Print Preview when no live data is active"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Add/Remove field row -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" x:Name="NewFieldBox"
                     ToolTip="Field names: letters, digits, underscore only"/>
            <Button Grid.Column="1" Content="+ Add" Padding="8,3" Margin="4,0,4,0"
                    Command="{Binding AddFieldCommand}"/>
            <Button Grid.Column="2" Content="Remove Selected" Padding="8,3"
                    Foreground="#C00" Command="{Binding RemoveFieldCommand}"/>
        </Grid>

        <!-- ── Print Qty column ── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Print Qty Column:" VerticalAlignment="Center"
                       Margin="0,0,8,0" FontWeight="SemiBold"/>
            <ComboBox Grid.Column="1" IsEditable="True"
                      ItemsSource="{Binding AvailableHeaders}"
                      DisplayMemberPath="Letter"
                      Text="{Binding PrintQtyColumn, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Column whose value = how many labels to print per row. Leave blank to always print 1.">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="ToolTip"  Value="{Binding Header}"/>
                        <Setter Property="Content"  Value="{Binding Display}"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
            <TextBlock Grid.Column="2" Text=" — leave blank to print 1 per row"
                       Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="OK_Click"
                    Background="#2196F3" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>

    </DockPanel>
</Window>
