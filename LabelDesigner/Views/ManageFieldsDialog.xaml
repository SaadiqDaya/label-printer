<Window x:Class="LabelDesigner.Views.ManageFieldsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LabelDesigner.Converters"
        Title="Manage Fields &amp; Excel Mapping"
        Width="580" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Template name header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding TemplateName, StringFormat='Template: {0}'}"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,14"/>

        <!-- ── Excel source file ── -->
        <TextBlock DockPanel.Dock="Top" Text="Excel Source File" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding ExcelPath}" IsReadOnly="True" Padding="4,3"
                     ToolTip="Excel file used when importing data for this template"/>
            <Button Grid.Column="1" Content="Browse…" Padding="8,3" Margin="4,0,0,0"
                    Command="{Binding BrowseExcelCommand}"/>
        </Grid>

        <!-- Column headers hint from the chosen Excel file -->
        <Border DockPanel.Dock="Top"
                Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1"
                Padding="6,4" Margin="0,0,0,12"
                Visibility="{Binding HasHeaderHint, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Available columns in this Excel file:" Foreground="#555" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding HeaderHint}" Foreground="#666" FontSize="10"
                           FontFamily="Consolas" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ── Field → Column mapping DataGrid ── -->
        <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,4">
            Field → Excel Column
            <Run Foreground="#888" FontSize="11" FontWeight="Normal"> — enter the column letter (A, B, C...) for each field</Run>
        </TextBlock>

        <DataGrid DockPanel.Dock="Top" Height="190" Margin="0,0,0,6"
                  ItemsSource="{Binding Mappings}"
                  SelectedItem="{Binding SelectedMapping}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Field Name"   Width="*"
                                    Binding="{Binding FieldName,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Excel Column" Width="110"
                                    Binding="{Binding ExcelColumn, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding TestValue, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Test Value"
                                   ToolTip="Sample value shown in Print Preview when no live data is active"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Add/Remove field row -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" x:Name="NewFieldBox"
                     ToolTip="Field names: letters, digits, underscore only"/>
            <Button Grid.Column="1" Content="+ Add" Padding="8,3" Margin="4,0,4,0"
                    Command="{Binding AddFieldCommand}"/>
            <Button Grid.Column="2" Content="Remove Selected" Padding="8,3"
                    Foreground="#C00" Command="{Binding RemoveFieldCommand}"/>
        </Grid>

        <!-- ── Print Qty column ── -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Print Qty Column:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding PrintQtyColumn, UpdateSourceTrigger=PropertyChanged}"
                     Width="50" Padding="4,3" FontFamily="Consolas"
                     ToolTip="Column letter that contains how many labels to print per row (e.g.  M)"/>
            <TextBlock Text=" — leave blank if every row prints 1 label"
                       Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,0,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="OK_Click"
                    Background="#2196F3" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>

    </DockPanel>
</Window>
