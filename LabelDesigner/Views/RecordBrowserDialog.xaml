<Window x:Class="LabelDesigner.Views.RecordBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Records"
        Width="640" Height="480"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource TenxsWindow}"
        ShowInTaskbar="False">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11" Foreground="#666"
                   Text="Double-click a record to jump to it."/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
        <DataGrid x:Name="RecordsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F5F5F5"
                  MouseDoubleClick="Grid_MouseDoubleClick"/>
    </DockPanel>
</Window>
