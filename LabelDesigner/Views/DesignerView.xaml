<UserControl x:Class="LabelDesigner.Views.DesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="clr-namespace:LabelDesigner.Designer"
             xmlns:conv="clr-namespace:LabelDesigner.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>    <!-- zoom bar -->
            <RowDefinition Height="*"/>     <!-- canvas area -->
            <RowDefinition Height="Auto"/>  <!-- record navigation -->
        </Grid.RowDefinitions>

        <!-- Zoom controls (ink bar) -->
        <Border Grid.Row="0" Background="{StaticResource Ink}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                <Button Content="−" Width="24" MinHeight="20" Margin="0,0,2,0" Padding="0"
                        Command="{Binding ZoomOutCommand}" Style="{StaticResource BtnDark}"/>
                <TextBlock Foreground="White" FontSize="11" VerticalAlignment="Center"
                           Margin="4,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}Zoom {0}%">
                            <Binding Path="ZoomPercent"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Content="+" Width="24" MinHeight="20" Margin="2,0,0,0" Padding="0"
                        Command="{Binding ZoomInCommand}" Style="{StaticResource BtnDark}"/>
                <Button Content="Reset" MinHeight="20" Padding="6,0" Margin="8,0,0,0"
                        Command="{Binding ZoomResetCommand}" Style="{StaticResource BtnDark}"/>
                <TextBlock Foreground="{StaticResource SidebarText}" FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0"
                           Text="{Binding TemplateName, StringFormat='  {0}'}"/>
                <TextBlock Foreground="#837B79" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}  {0:F1} × {1:F1} mm">
                            <Binding Path="WidthMm"/>
                            <Binding Path="HeightMm"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Canvas area (warm dark workspace so the white label pops) -->
        <Grid Grid.Row="1" Background="#4A4546">
            <ScrollViewer x:Name="MainScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Drop shadow wrapper -->
                    <Border>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="5" Opacity="0.55"/>
                        </Border.Effect>

                        <!-- Label canvas — LayoutTransform scales it for display while preserving coordinates -->
                        <designer:DesignerCanvas x:Name="LabelCanvas"
                                                 Width="{Binding CanvasWidthPx}"
                                                 Height="{Binding CanvasHeightPx}"
                                                 Background="White"
                                                 Focusable="True"
                                                 ClipToBounds="True">
                            <designer:DesignerCanvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ViewportScale}"
                                                ScaleY="{Binding ViewportScale}"/>
                            </designer:DesignerCanvas.LayoutTransform>
                        </designer:DesignerCanvas>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
        <!-- Row 2: Record navigation bar — visible when a data file is connected -->
        <Border Grid.Row="2" Background="{StaticResource Ink}" Padding="6,4"
                Visibility="{Binding HasConnectedFile, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Load + Unload buttons always shown when file is connected -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="⟳ Load" MinHeight="22" Padding="10,0"
                            Command="{Binding LoadDataCommand}"
                            ToolTip="Load / refresh rows from the connected Excel file"/>
                    <Button Content="⊘ Unload" MinHeight="22" Padding="8,0" Margin="6,0,0,0"
                            Command="{Binding ClearDataCommand}"
                            Style="{StaticResource BtnDanger}"
                            Visibility="{Binding HasRows, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Disconnect live data and revert to template placeholders"/>
                </StackPanel>

                <!-- Navigation — centred, only visible when rows are loaded -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="{Binding HasRows, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="◄ Prev" Width="62" MinHeight="22" Margin="0,0,4,0"
                            Command="{Binding PreviousRowCommand}" Style="{StaticResource BtnDark}"/>
                    <TextBlock Text="{Binding RowInfo}" Foreground="{StaticResource SidebarText}" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Text="Go to:" Foreground="#837B79" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,2,0"/>
                    <TextBox x:Name="GotoRowBox" Width="48" Height="20" Padding="2,1"
                             Text="{Binding CurrentRowNumber, UpdateSourceTrigger=LostFocus}"
                             KeyDown="GotoRowBox_KeyDown"
                             ToolTip="Type a record number and press Enter"
                             VerticalContentAlignment="Center"/>
                    <Button Content="Browse…" MinHeight="22" Padding="8,0" Margin="6,0,0,0"
                            Command="{Binding BrowseRecordsCommand}" Style="{StaticResource BtnDark}"
                            ToolTip="Open full record list"/>
                    <Button Content="Next ►" Width="62" MinHeight="22" Margin="4,0,0,0"
                            Command="{Binding NextRowCommand}" Style="{StaticResource BtnDark}"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
