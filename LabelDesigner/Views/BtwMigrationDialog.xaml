<Window x:Class="LabelDesigner.Views.BtwMigrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Migrate BarTender Templates" Width="900" Height="560"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource TenxsWindow}" MinWidth="760" MinHeight="420"
        ShowInTaskbar="False">
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,10"
                   Text="Tracks the rebuild of your BarTender library. Scan your .btw folder, then create a skeleton per label: the .lbl gets the correct size and name, an optional locked backdrop image to trace over (it never prints), and optionally the fields from the label's data file. BarTender's file format cannot be converted losslessly — rebuild each label, test-print it, then set its status to Done. Progress is saved in the shared templates folder, so every station sees it."/>

        <!-- Folder + scan row -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="BarTender folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button DockPanel.Dock="Right" Content="Scan" Width="90" Margin="8,0,0,0"
                    Command="{Binding ScanCommand}"/>
            <Button DockPanel.Dock="Right" Content="Browse…" Width="90" Margin="8,0,0,0"
                    Command="{Binding BrowseCommand}"/>
            <TextBox Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Bottom: summary + close -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="Close" Width="90" IsCancel="True"/>
            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Right: actions -->
        <StackPanel DockPanel.Dock="Right" Margin="8,0,0,0" Width="170">
            <Button Content="Create skeleton…" Margin="0,0,0,6" Padding="0,4"
                    Command="{Binding CreateSkeletonCommand}"
                   
                    ToolTip="Create the .lbl for the selected file — asks about a backdrop image and data-file fields."/>
            <Button Content="Create all pending" Margin="0,0,0,6" Padding="0,4"
                    Command="{Binding CreateAllPendingCommand}"
                    ToolTip="Blank skeletons (size + name only) for every Pending file."/>
            <Button Content="Open in Designer" Margin="0,0,0,6" Padding="0,4"
                    Command="{Binding OpenTargetCommand}"
                    ToolTip="Closes this window and opens the selected file's target template."/>
            <TextBlock TextWrapping="Wrap" Foreground="#777" FontSize="11" Margin="0,8,0,0"
                       Text="Statuses: Pending → Skeleton created → In progress → Done. Use Skipped for labels you no longer need. Notes are free text."/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Entries}" SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" SelectionMode="Single" IsReadOnly="False">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProblem}" Value="True">
                            <Setter Property="Foreground" Value="#B00020"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" IsReadOnly="True" Width="200"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" IsReadOnly="True" Width="90"/>
                <DataGridTextColumn Header="BT printer" Binding="{Binding Printer}" IsReadOnly="True" Width="110"/>
                <DataGridTemplateColumn Header="Status" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="!" Binding="{Binding ProblemText}" IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="→ Template" Binding="{Binding TargetTemplateName}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
