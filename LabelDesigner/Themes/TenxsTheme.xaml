<!-- ============================================================================
     Tenxs ERP (Jvnction 2026) design system, ported to WPF.
     Source of truth: JaneERP\Theme.cs — ink #231F20 sidebar/headers, cyan #06C0D3
     brand accent/CTA, purple #6A4BF2 secondary, warm off-white #F8F6F5 page,
     white rounded cards with hairline borders, Archivo / Hanken Grotesk /
     JetBrains Mono type. Buttons are SOLID for live actions (grey/outline reads
     as disabled); disabled buttons go #8C8C8C with near-black text.
     Merged app-wide from App.xaml; windows opt in with Style="{StaticResource TenxsWindow}".
     ============================================================================ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PageBg"        Color="#F8F6F5"/>
    <SolidColorBrush x:Key="Surface"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Sunken"        Color="#F1EEEC"/>
    <SolidColorBrush x:Key="Hairline"      Color="#E4DFDD"/>
    <SolidColorBrush x:Key="BorderStrong"  Color="#CBC4C1"/>
    <SolidColorBrush x:Key="Ink"           Color="#231F20"/>
    <SolidColorBrush x:Key="InkHover"      Color="#303238"/>
    <SolidColorBrush x:Key="SidebarText"   Color="#CEC9C6"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#231F20"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#615A58"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#837B79"/>
    <SolidColorBrush x:Key="Cyan"          Color="#06C0D3"/>
    <SolidColorBrush x:Key="CyanHover"     Color="#22C7DA"/>
    <SolidColorBrush x:Key="CyanPress"     Color="#079BAB"/>
    <SolidColorBrush x:Key="CyanText"      Color="#0A7B89"/>
    <SolidColorBrush x:Key="CyanTint"      Color="#ECFCFE"/>
    <SolidColorBrush x:Key="Purple"        Color="#6A4BF2"/>
    <SolidColorBrush x:Key="PurpleHover"   Color="#7C3AED"/>
    <SolidColorBrush x:Key="PurplePress"   Color="#4C1D95"/>
    <SolidColorBrush x:Key="PurpleText"    Color="#5436D6"/>
    <SolidColorBrush x:Key="PurpleTint"    Color="#F0ECFE"/>
    <SolidColorBrush x:Key="Danger"        Color="#E8503A"/>
    <SolidColorBrush x:Key="DangerHover"   Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerPress"   Color="#B91C1C"/>
    <SolidColorBrush x:Key="DangerTint"    Color="#FDEBE8"/>
    <SolidColorBrush x:Key="DangerText"    Color="#B71C1C"/>
    <SolidColorBrush x:Key="Amber"         Color="#F2A93B"/>
    <SolidColorBrush x:Key="AmberTint"     Color="#FDF3E2"/>
    <SolidColorBrush x:Key="AmberText"     Color="#A86C12"/>
    <SolidColorBrush x:Key="DisabledBg"    Color="#8C8C8C"/>
    <SolidColorBrush x:Key="DisabledFg"    Color="#1E1E1E"/>

    <!-- ── Type system (bundled brand fonts with graceful fallbacks) ──────── -->
    <FontFamily x:Key="BodyFont">pack://application:,,,/Fonts/#Hanken Grotesk, Segoe UI</FontFamily>
    <FontFamily x:Key="BodyMediumFont">pack://application:,,,/Fonts/#Hanken Grotesk Medium, pack://application:,,,/Fonts/#Hanken Grotesk, Segoe UI</FontFamily>
    <FontFamily x:Key="BodySemiFont">pack://application:,,,/Fonts/#Hanken Grotesk SemiBold, pack://application:,,,/Fonts/#Hanken Grotesk, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">pack://application:,,,/Fonts/#Archivo, Arial Narrow, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">pack://application:,,,/Fonts/#JetBrains Mono, Consolas</FontFamily>

    <!-- ── Window base ─────────────────────────────────────────────────────── -->
    <Style x:Key="TenxsWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource PageBg}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- Text helpers -->
    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>
    <!-- JetBrains Mono uppercase "eyebrow" — section labels, the ERP signature. -->
    <Style x:Key="EyebrowText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
    </Style>
    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ── Buttons ─────────────────────────────────────────────────────────── -->
    <!-- Shared rounded-flat template; colour comes from the style's setters. -->
    <ControlTemplate x:Key="TenxsButtonTemplate" TargetType="ButtonBase">
        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8" SnapsToDevicePixels="True">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
        </Border>
    </ControlTemplate>

    <!-- Default (implicit) button = the cyan CTA. Live actions are solid, per house rule. -->
    <Style TargetType="Button">
        <Setter Property="Template" Value="{StaticResource TenxsButtonTemplate}"/>
        <Setter Property="Background" Value="{StaticResource Cyan}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource BodySemiFont}"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="MinHeight" Value="27"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanPress}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBg}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledFg}"/>
            </Trigger>
            <!-- Cancel/Close buttons (IsCancel) automatically read as secondary — solid
                 colour stays reserved for live actions. Placed last so it wins the hover. -->
            <Trigger Property="IsCancel" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsCancel" Value="True"/>
                    <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsCancel" Value="True"/>
                    <Condition Property="IsPressed" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Hairline}"/>
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnPurple" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Purple}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PurpleHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PurplePress}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBg}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Danger}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerPress}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBg}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Ghost: white card button for genuinely secondary actions (Cancel/Close only). -->
    <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Hairline}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Quiet button for dark (ink) bars — zoom bar, record navigation. -->
    <Style x:Key="BtnDark" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="MinHeight" Value="22"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource InkHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#4A4546"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#6E6867"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Big CTA (Print Station PRINT / PRINT JOB). -->
    <Style x:Key="BtnCta" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <!-- ToolBar swaps in its own style keys, so the implicit Button style above
         does NOT reach toolbar buttons — these do. Quiet by default; accents below. -->
    <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource TenxsButtonTemplate}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyMediumFont}"/>
        <Setter Property="Padding" Value="9,4"/>
        <Setter Property="Margin" Value="1,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Hairline}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="{x:Static ToolBar.ToggleButtonStyleKey}" TargetType="ToggleButton">
        <Setter Property="Template" Value="{StaticResource TenxsButtonTemplate}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyMediumFont}"/>
        <Setter Property="Padding" Value="9,4"/>
        <Setter Property="Margin" Value="1,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanTint}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Cyan}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Accented toolbar buttons (assigned explicitly in MainWindow). -->
    <Style x:Key="ToolBtnAccent" TargetType="Button" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
        <Setter Property="Background" Value="{StaticResource CyanTint}"/>
        <Setter Property="Foreground" Value="{StaticResource CyanText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Cyan}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ToolBtnPurple" TargetType="Button" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
        <Setter Property="Background" Value="{StaticResource PurpleTint}"/>
        <Setter Property="Foreground" Value="{StaticResource PurpleText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Purple}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ToolBtnDanger" TargetType="Button" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerTint}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ToolBtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
        <Setter Property="Background" Value="{StaticResource Cyan}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource BodySemiFont}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanPress}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
    </Style>
    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
    </Style>
    <Style x:Key="{x:Static ToolBar.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Hairline}"/>
        <Setter Property="Margin" Value="4,4"/>
    </Style>
    <Style x:Key="{x:Static ToolBar.TextBoxStyleKey}" TargetType="TextBox">
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="3,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── Standalone ToggleButton (outside toolbars) ──────────────────────── -->
    <Style TargetType="ToggleButton">
        <Setter Property="Template" Value="{StaticResource TenxsButtonTemplate}"/>
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Sunken}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanTint}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Cyan}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Inputs ──────────────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Cyan}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Sunken}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Sunken}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box" Width="15" Height="15" CornerRadius="4"
                                Background="{StaticResource Surface}"
                                BorderBrush="{StaticResource BorderStrong}" BorderThickness="1.2"
                                VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <Path x:Name="Check" Data="M 2.5,7 L 6,10.5 L 12,3.5" Stroke="White" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Cyan}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Sunken}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox: colours + editable-box padding only; the system template keeps
         its dropdown behaviour (full retemplates break IsEditable interaction). -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="2,0"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CyanTint}"/>
                            <Setter Property="Foreground" Value="{StaticResource CyanText}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Lists ───────────────────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Sunken}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CyanTint}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ListView keeps the same row feel. -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Tabs (underline style) ──────────────────────────────────────────── -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyMediumFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Background="Transparent" Padding="10,6,10,4">
                        <StackPanel>
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                            <Rectangle x:Name="Underline" Height="2.5" Margin="0,4,0,0"
                                       RadiusX="1.25" RadiusY="1.25" Fill="Transparent"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Underline" Property="Fill" Value="{StaticResource Cyan}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="FontFamily" Value="{StaticResource BodySemiFont}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── GroupBox = white card with an eyebrow header ────────────────────── -->
    <Style TargetType="GroupBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Hairline}"
                            BorderThickness="1" CornerRadius="8" Padding="8" SnapsToDevicePixels="True">
                        <DockPanel>
                            <ContentPresenter DockPanel.Dock="Top" ContentSource="Header"
                                              TextElement.FontFamily="{StaticResource MonoFont}"
                                              TextElement.FontSize="10"
                                              TextElement.Foreground="{StaticResource TextMuted}"
                                              Margin="0,0,0,6"/>
                            <ContentPresenter/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Menu / status bar / splitters ───────────────────────────────────── -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource Ink}"/>
        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
        <Setter Property="FontSize" Value="11.5"/>
    </Style>
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource PageBg}"/>
    </Style>

    <!-- ── DataGrid (ink header, hairline rows — the ERP grid) ─────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{StaticResource Surface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource PageBg}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="MinRowHeight" Value="26"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Ink}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource BodySemiFont}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="#3A3536"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource CyanTint}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Cards & tiles ───────────────────────────────────────────────────── -->
    <!-- White card container (matches the ERP tile card). -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Icon chip: 40×40 rounded square with a tinted background (ERP tile chip). -->
    <Style x:Key="IconChip" TargetType="Border">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{StaticResource CyanTint}"/>
    </Style>
    <Style x:Key="IconChipGlyph" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource CyanText}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Tile list item: white rounded card, hairline border, cyan border on
         hover/selection — the main-menu tile behaviour. Use on ListBoxes whose
         ItemTemplate is a tile (Print Station template picker). -->
    <Style x:Key="TileListItem" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            CornerRadius="12" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.6"/>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CyanTint}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="TileList" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource TileListItem}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

</ResourceDictionary>
